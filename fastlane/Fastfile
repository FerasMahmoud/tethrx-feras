default_platform(:ios)

platform :ios do
  desc "Build, sign, upload TethrX Feras to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_KEY"),
      in_house: false,
      duration: 1200
    )

    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key: ENV.fetch("ASC_KEY")
    )

    # Register bundle IDs on Developer portal (required before match profiles)
    [
      ["uk.firashome.tethrx", "TethrX Feras"],
      ["uk.firashome.tethrx.widget", "TethrX Feras Widget"]
    ].each do |bid, name|
      existing = Spaceship::ConnectAPI::BundleId.find(bid)
      if existing
        UI.success("Bundle ID exists: #{bid}")
      else
        UI.message("Creating Bundle ID #{bid} …")
        Spaceship::ConnectAPI::BundleId.create(
          name: name,
          identifier: bid,
          platform: "IOS"
        )
      end
    rescue => e
      UI.important("BundleId #{bid}: #{e.message}")
    end

    # App Store Connect app record (needs Admin; soft-fail if key cannot CREATE)
    begin
      if Spaceship::ConnectAPI::App.find("uk.firashome.tethrx").nil?
        UI.message("Creating ASC app uk.firashome.tethrx …")
        Spaceship::ConnectAPI::App.create(
          name: "TethrX Feras",
          version_string: "1.0",
          sku: "firashome-tethrx-#{Time.now.to_i}",
          primary_locale: "en-US",
          bundle_id: "uk.firashome.tethrx",
          platforms: ["IOS"]
        )
      end
    rescue => e
      UI.important("ASC app ensure: #{e.message}")
    end

    # Certs + profiles for app + widget
    match(
      type: "appstore",
      app_identifier: ["uk.firashome.tethrx", "uk.firashome.tethrx.widget"],
      readonly: false,
      api_key: api_key
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "ios/GrokRemote.xcodeproj",
      team_id: "3V4NW789C6",
      code_sign_identity: "iPhone Distribution",
      profile_name: "match AppStore uk.firashome.tethrx",
      bundle_identifier: "uk.firashome.tethrx",
      targets: ["GrokRemote"]
    )
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "ios/GrokRemote.xcodeproj",
      team_id: "3V4NW789C6",
      code_sign_identity: "iPhone Distribution",
      profile_name: "match AppStore uk.firashome.tethrx.widget",
      bundle_identifier: "uk.firashome.tethrx.widget",
      targets: ["TethrXWidget"]
    )

    build_number = ENV.fetch("BUILD_NUMBER", Time.now.strftime("%Y%m%d%H%M"))
    increment_build_number(
      build_number: build_number,
      xcodeproj: "ios/GrokRemote.xcodeproj"
    )

    gym(
      scheme: "GrokRemote",
      project: "ios/GrokRemote.xcodeproj",
      export_method: "app-store",
      clean: true,
      include_bitcode: false,
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        teamID: "3V4NW789C6",
        provisioningProfiles: {
          "uk.firashome.tethrx" => "match AppStore uk.firashome.tethrx",
          "uk.firashome.tethrx.widget" => "match AppStore uk.firashome.tethrx.widget"
        }
      },
      xcargs: [
        "CODE_SIGN_STYLE=Manual",
        'CODE_SIGN_IDENTITY="iPhone Distribution"',
        "DEVELOPMENT_TEAM=3V4NW789C6"
      ].join(" ")
    )

    pilot(
      api_key: api_key,
      app_identifier: "uk.firashome.tethrx",
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )
  end
end
