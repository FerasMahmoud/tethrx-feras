default_platform(:ios)

platform :ios do
  desc "Build, sign, upload TethrX Feras to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_KEY"),
      in_house: false,
      duration: 1200
    )

    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key: ENV.fetch("ASC_KEY")
    )

    # Register bundle IDs + Push + App Groups before match.
    # App Group id must exist on the team; we enable the capability and force profiles.
    APP_GROUP_ID = "group.uk.firashome.tethrx"

    def ensure_bundle!(identifier, name, capabilities:)
      bid = Spaceship::ConnectAPI::BundleId.find(identifier)
      unless bid
        UI.message("Creating Bundle ID #{identifier} …")
        bid = Spaceship::ConnectAPI::BundleId.create(
          name: name,
          identifier: identifier,
          platform: "IOS"
        )
      end
      capabilities.each do |cap|
        begin
          bid.create_capability(cap)
          UI.success("Enabled #{cap} on #{identifier}")
        rescue => e
          # already enabled is fine
          UI.important("#{identifier} capability #{cap}: #{e.message}")
        end
      end
      bid
    end

    # Best-effort: create App Group identifier via Portal if available.
    begin
      if defined?(Spaceship::Portal) && Spaceship::Portal.client
        existing = Spaceship::Portal.app_group.all rescue []
        unless existing.any? { |g| g.group_id == APP_GROUP_ID || g.app_group_id == APP_GROUP_ID }
          UI.message("Creating App Group #{APP_GROUP_ID} …")
          Spaceship::Portal.app_group.create!(group_identifier: APP_GROUP_ID, name: "TethrX Feras") rescue nil
        end
      end
    rescue => e
      UI.important("App Group create (Portal): #{e.message} — create group.uk.firashome.tethrx once in Developer portal if match fails")
    end

    ensure_bundle!(
      "uk.firashome.tethrx",
      "TethrX Feras",
      capabilities: [
        Spaceship::ConnectAPI::BundleIdCapability::Type::PUSH_NOTIFICATIONS,
        Spaceship::ConnectAPI::BundleIdCapability::Type::APP_GROUPS
      ]
    )
    ensure_bundle!(
      "uk.firashome.tethrx.widget",
      "TethrX Feras Widget",
      capabilities: [
        Spaceship::ConnectAPI::BundleIdCapability::Type::APP_GROUPS
      ]
    )

    # App Store Connect app record (needs Admin; soft-fail if key cannot CREATE)
    begin
      if Spaceship::ConnectAPI::App.find("uk.firashome.tethrx").nil?
        UI.message("Creating ASC app uk.firashome.tethrx …")
        Spaceship::ConnectAPI::App.create(
          name: "TethrX Feras",
          version_string: "1.0",
          sku: "firashome-tethrx-#{Time.now.to_i}",
          primary_locale: "en-US",
          bundle_id: "uk.firashome.tethrx",
          platforms: ["IOS"]
        )
      end
    rescue => e
      UI.important("ASC app ensure: #{e.message}")
    end

    # Force regenerate profiles so aps-environment lands in the main app profile.
    match(
      type: "appstore",
      app_identifier: ["uk.firashome.tethrx", "uk.firashome.tethrx.widget"],
      readonly: false,
      force: true,
      api_key: api_key
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "ios/GrokRemote.xcodeproj",
      team_id: "3V4NW789C6",
      code_sign_identity: "iPhone Distribution",
      profile_name: "match AppStore uk.firashome.tethrx",
      bundle_identifier: "uk.firashome.tethrx",
      targets: ["GrokRemote"]
    )
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "ios/GrokRemote.xcodeproj",
      team_id: "3V4NW789C6",
      code_sign_identity: "iPhone Distribution",
      profile_name: "match AppStore uk.firashome.tethrx.widget",
      bundle_identifier: "uk.firashome.tethrx.widget",
      targets: ["TethrXWidget"]
    )

    build_number = ENV.fetch("BUILD_NUMBER", Time.now.strftime("%Y%m%d%H%M"))
    increment_build_number(
      build_number: build_number,
      xcodeproj: "ios/GrokRemote.xcodeproj"
    )

    # Archive only — gym's export_method injects "app-store" which Xcode 16 rejects.
    gym(
      scheme: "GrokRemote",
      project: "ios/GrokRemote.xcodeproj",
      clean: true,
      skip_package_ipa: true,
      skip_package_pkg: true,
      include_bitcode: false,
      xcargs: [
        "CODE_SIGN_STYLE=Manual",
        'CODE_SIGN_IDENTITY="iPhone Distribution"',
        "DEVELOPMENT_TEAM=3V4NW789C6"
      ].join(" ")
    )

    archive_path = lane_context[SharedValues::XCODEBUILD_ARCHIVE]
    root = File.expand_path("..", __dir__)
    export_dir = File.join(root, "build", "export")
    export_plist = File.join(root, "ios", "ExportOptions.plist")
    UI.user_error!("Missing #{export_plist}") unless File.exist?(export_plist)
    FileUtils.rm_rf(export_dir)
    FileUtils.mkdir_p(export_dir)
    sh(
      "xcodebuild", "-exportArchive",
      "-archivePath", archive_path,
      "-exportPath", export_dir,
      "-exportOptionsPlist", export_plist
    )
    ipa = Dir["#{export_dir}/*.ipa"].first
    UI.user_error!("No IPA after export") unless ipa
    UI.success("Exported #{ipa}")

    pilot(
      api_key: api_key,
      app_identifier: "uk.firashome.tethrx",
      ipa: ipa,
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )
  end
end
